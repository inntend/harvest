{
  "name": "@inntend/harvest",
  "version": "0.0.1",
  "type": "module",
  "description": "Plugin-based connector runtime — pull and push external data on demand",
  "license": "MIT",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "import": "./dist/react.js",
      "default": "./dist/react.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "engines": {
    "npm": "=10.x",
    "node": "=24.x"
  },
  "packageManager": "pnpm@11.9.0",
  "scripts": {
    "build": "tsup",
    "build:check": "tsc --noEmit",
    "test": "vitest run --project unit",
    "test:integration": "vitest run --project integration",
    "test:coverage": "vitest run --project unit --coverage",
    "check": "biome check --write",
    "check:ci": "biome ci",
    "validate": "pnpm run check && pnpm run build:check && pnpm run test:coverage"
  },
  "dependencies": {
    "@inntend/convert": "0.0.6"
  },
  "peerDependencies": {
    "react": ">=18",
    "zod": "4.x"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.17",
    "@vitest/coverage-v8": "^4.1.9",
    "react": "^19.2.7",
    "react-dom": "19.2.7",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vite": "^8.1.0",
    "vitest": "^4.1.9",
    "zod": "^4.4.3"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/inntend/harvest.git"
  },
  "bugs": {
    "url": "https://github.com/inntend/harvest/issues"
  },
  "homepage": "https://github.com/inntend/harvest/"
}
