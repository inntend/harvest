{
  "$schema": "https://biomejs.dev/schemas/2.5.1/schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "files": {
    "ignoreUnknown": false,
    "includes": ["**", "!dist/*", "!coverage/*"]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineEnding": "lf",
    "lineWidth": 80,
    "bracketSpacing": true
  },
  "linter": {
    "enabled": true,
    "rules": {
      "preset": "none",
      "correctness": {
        "noUnreachable": "warn",
        "noUnusedVariables": "warn",
        "noUnusedImports": "warn",
        "useIsNan": "error",
        "useValidTypeof": "error"
      },
      "suspicious": {
        "noDoubleEquals": "warn",
        "noDuplicateParameters": "error",
        "noDuplicateObjectKeys": "error",
        "noRedeclare": "warn",
        "noVar": "error"
      },
      "style": {
        "useConsistentArrayType": {
          "level": "warn",
          "options": { "syntax": "shorthand" }
        },
        "useConst": "warn",
        "useImportType": "warn"
      },
      "complexity": {
        "noUselessConstructor": "warn",
        "useOptionalChain": "warn"
      }
    }
  },
  "javascript": {
    "formatter": {
      "quoteProperties": "asNeeded",
      "trailingCommas": "all",
      "semicolons": "always",
      "arrowParentheses": "always",
      "quoteStyle": "single"
    }
  },
  "assist": {
    "enabled": true,
    "actions": {
      "source": { "organizeImports": "on" }
    }
  }
}
